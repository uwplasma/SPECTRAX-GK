recursive-include examples *.py *.toml
recursive-include docs *.rst *.py
recursive-include src/spectraxgk/data *.csv
include README.md LICENSE
prune docs/_build
prune docs/_static
prune build
prune dist
prune tools_out
prune .cache
prune .pytest_cache
prune .ruff_cache
global-exclude __pycache__ *.py[cod] .DS_Store
